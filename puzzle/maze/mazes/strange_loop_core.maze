{"version":1,"cols":4,"rows":3,"start":[0,0],"end":[3,2],"name":"strange_loop.core","subline":"\"It turns out that an eerie type of chaos can lurk just behind a facade of order — and yet, deep inside the chaos lurks an even eerier type of order.\" — Douglas Hofstadter, Gödel, Escher, Bach (1979)","time_limit":0,"h":[[1,1,1],[1,1,1],[1,1,1]],"v":[[1,1,1,1],[1,1,1,1]],"cells":[[1,2,1],[0,2,0]]}