; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Hack The Planet"
run/main_scene="res://menu/main_menu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.png"

[audio]

buses/default_bus_layout="uid://bjew6xi7wqh2a"

[autoload]

Events="*res://autoload/events.gd"
DebugPanel="*res://autoload/debug_panel.gd"
Layers="*res://autoload/layers.gd"
GameState="*res://autoload/game_state.gd"
Audio="*res://autoload/audio.gd"
Dialogue="*res://autoload/dialogue.gd"
Puzzles="*res://autoload/puzzles.gd"
Skills="*res://autoload/skills.gd"
Settings="*res://autoload/settings.gd"
SceneLoader="*res://autoload/scene_loader.gd"
SaveService="*res://autoload/save_service.gd"
LevelProgression="*res://autoload/level_progression.gd"
PauseController="*res://autoload/pause_controller.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
HandlePicker="*res://autoload/handle_picker.gd"
Walkie="*res://autoload/walkie.gd"
Companion="*res://autoload/companion.gd"
VoicePrimer="*res://autoload/voice_primer.gd"
Glyphs="*res://autoload/glyphs.gd"
Beacons="*res://autoload/beacons.gd"
Cutscene="*res://autoload/cutscene.gd"

[dialogue_manager]

general/wrap_lines=true
general/states=["GameState", "Events", "Audio", "Skills", "HandlePicker", "Walkie", "Companion", "Cutscene"]
runtime/balloon_path="res://dialogue/scroll_balloon.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/initial_screen=1
window/size/window_width_override=2560
window/size/window_height_override=1440
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

